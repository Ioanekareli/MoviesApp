<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/moviesListFragment">

    <fragment
        android:id="@+id/moviesListFragment"
        android:name="com.example.moviesapplication.ui.movieslist.MoviesListFragment"
        android:label="fragment_movies_list"
        tools:layout="@layout/fragment_movies_list" >
        <action
            android:id="@+id/action_moviesListFragment_to_moviesDetailFragment"
            app:destination="@id/moviesDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/moviesDetailFragment"
        android:name="com.example.moviesapplication.ui.moviesdetail.MoviesDetailFragment"
        android:label="fragment_movies_detail"
        tools:layout="@layout/fragment_movies_detail" >
        <argument
            android:name="result"
            app:argType="com.example.moviesapplication.dto.Result" />
    </fragment>
</navigation>